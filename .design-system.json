{
  "name": "ctrlswing",
  "version": "1.0.0",

  "colors": {
    "brand": {
      "yellow": "#ffe17c",
      "charcoal": "#171e19",
      "darkgray": "#272727",
      "sage": "#b7c6c2"
    },
    "semantic": {
      "error": "#ef4444",
      "success": "#4ade80"
    },
    "surface": {
      "background": "#ffffff",
      "foreground": "#171e19",
      "muted": "#b7c6c2",
      "card-dark": "#272727",
      "border": "rgba(23, 30, 25, 0.10)"
    },
    "browser-chrome": {
      "close": "#f87171",
      "minimize": "#ffe17c",
      "expand": "#4ade80"
    }
  },

  "typography": {
    "families": {
      "heading": "Anton",
      "body": "Satoshi"
    },
    "heading-scale": {
      "display": { "size": "clamp(3.75rem, 8vw, 9rem)", "lineHeight": "0.9", "weight": 400, "transform": "uppercase" },
      "h1": { "size": "clamp(3rem, 6vw, 3.75rem)", "lineHeight": "0.9", "weight": 400, "transform": "uppercase" },
      "h2": { "size": "clamp(2.25rem, 4vw, 3rem)", "lineHeight": "0.9", "weight": 400, "transform": "uppercase" },
      "h3": { "size": "1.5rem", "lineHeight": "1.1", "weight": 400, "transform": "uppercase" },
      "h4": { "size": "1.25rem", "lineHeight": "1.1", "weight": 400, "transform": "uppercase" }
    },
    "body-weights": {
      "normal": 400,
      "medium": 500,
      "bold": 700
    }
  },

  "spacing": {
    "unit": "4px",
    "section-padding": {
      "y": { "mobile": "6rem", "desktop": "8rem" },
      "x": "1.5rem"
    }
  },

  "radii": {
    "sm": "0.375rem",
    "md": "0.5rem",
    "lg": "0.75rem",
    "xl": "1rem",
    "2xl": "1.5rem",
    "full": "9999px"
  },

  "shadows": {
    "sm": "0 1px 2px rgba(0,0,0,0.05)",
    "md": "0 4px 6px -1px rgba(0,0,0,0.07), 0 2px 4px -2px rgba(0,0,0,0.05)",
    "lg": "0 10px 15px -3px rgba(0,0,0,0.08), 0 4px 6px -4px rgba(0,0,0,0.04)",
    "xl": "0 20px 25px -5px rgba(0,0,0,0.1), 0 8px 10px -6px rgba(0,0,0,0.04)",
    "2xl": "0 25px 50px -12px rgba(0,0,0,0.15)",
    "yellow-glow": "0 8px 30px rgba(255,225,124,0.4)",
    "yellow-glow-hover": "0 8px 30px rgba(23,30,25,0.4)",
    "yellow-subtle": "0 4px 20px rgba(255,225,124,0.3)",
    "yellow-faint": "0 4px 20px rgba(255,225,124,0.2)"
  },

  "motion": {
    "durations": {
      "fast": "200ms",
      "normal": "300ms",
      "slow": "500ms"
    },
    "easings": {
      "default": "cubic-bezier(0.4, 0, 0.2, 1)",
      "in": "cubic-bezier(0.4, 0, 1, 1)",
      "out": "cubic-bezier(0, 0, 0.2, 1)"
    }
  },

  "opacity-scale": {
    "border": "0.10",
    "muted-text": "0.50",
    "secondary-text": "0.70",
    "primary-text": "0.80",
    "subtle-bg": "0.05"
  },

  "patterns": {
    "grid-light": "linear-gradient(to right, rgba(23,30,25,0.05) 1px, transparent 1px), linear-gradient(to bottom, rgba(23,30,25,0.05) 1px, transparent 1px)",
    "grid-dark": "linear-gradient(to right, rgba(183,198,194,0.05) 1px, transparent 1px), linear-gradient(to bottom, rgba(183,198,194,0.05) 1px, transparent 1px)",
    "grid-size": "40px 40px"
  },

  "constraints": {
    "maxUniqueColors": 8,
    "maxFontFamilies": 2,
    "maxAccentColors": 1,
    "maxBorderRadii": 6,
    "maxShadowLevels": 4
  }
}
